# ============================================================
# profiles.yml.example — Google Fiber FCR Capstone
# ============================================================
# ⚠️  IMPORTANT: This is a TEMPLATE. Do NOT use directly.
#
# Setup:
#   1. Copy this file to ~/.dbt/profiles.yml
#        mkdir -p ~/.dbt
#        cp dbt/profiles.yml.example ~/.dbt/profiles.yml
#   2. Edit ~/.dbt/profiles.yml and replace placeholders:
#        - your-gcp-project-id
#        - /absolute/path/to/your/gcp-sa-key.json
#   3. For dev: run `gcloud auth application-default login`
#   4. Verify: `cd dbt && dbt debug`
#
# Why outside the repo?
#   profiles.yml contains credentials (or paths to them).
#   Following dbt Labs best practices + Twelve-Factor App,
#   environment-specific config must NEVER be committed.
# ============================================================

google_fiber:
  target: dev

  outputs:
    # ── DEV: local development with personal credentials ────
    dev:
      type: bigquery
      method: oauth                       # uses `gcloud auth application-default login`
      project: your-gcp-project-id        # ← REPLACE: your GCP project ID (e.g. gbi-test)
      dataset: dbt_dev                    # dbt will write to this dataset
      location: US                        # ← REPLACE if your BigQuery region differs
      threads: 4
      timeout_seconds: 300
      priority: interactive

    # ── PROD: CI/CD with service account ────────────────────
    prod:
      type: bigquery
      method: service-account
      project: your-gcp-project-id        # ← REPLACE: your GCP project ID
      dataset: dbt_prod                   # production mart dataset
      keyfile: /absolute/path/to/gcp-sa-key.json  # ← REPLACE: SA key path (NEVER commit the key)
      location: US
      threads: 8
      timeout_seconds: 300
      priority: batch

# ============================================================
# .gitignore — Google Fiber FCR Capstone
# ============================================================
# Block secrets, build artifacts, and OS junk
# ============================================================

# ── Secrets / Credentials ───────────────────────────────────
# NEVER commit these. profiles.yml lives at ~/.dbt/profiles.yml only.
**/profiles.yml
.env
.env.*
!.env.example
*.key
*.pem
gcp-sa-key*.json
service-account*.json
*-credentials.json
secrets/

# ── dbt build artifacts ─────────────────────────────────────
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# ── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── BI tool temp files ──────────────────────────────────────
# Tableau backup/lock
*.twbx.bak
*.twb.lock
# Power BI temp
*.pbix.tmp
~$*.pbix

# ── OS junk ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*~
*.swp
*.swo

# ── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.iml
.cursor/

# ── Misc ────────────────────────────────────────────────────
*.log
*.tmp
